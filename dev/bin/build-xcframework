#!/usr/bin/env bash
# Build ZettelDB XCFramework for iOS/macOS.
# Requires: Xcode, rustup iOS targets.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
OUT="$ROOT/out/swift"
LIB_NAME="libzdb_core.a"

TARGETS=(
    aarch64-apple-ios
    aarch64-apple-ios-sim
    x86_64-apple-ios
    aarch64-apple-darwin
)

# Check prerequisites
for t in "${TARGETS[@]}"; do
    if ! rustup target list --installed | grep -q "$t"; then
        echo "Missing target: $t"
        echo "Install with: rustup target add $t"
        exit 1
    fi
done

command -v xcodebuild >/dev/null 2>&1 || { echo "xcodebuild not found — install Xcode"; exit 1; }

echo "==> Building for ${#TARGETS[@]} targets..."
for t in "${TARGETS[@]}"; do
    cargo build -p zdb-core --release --target "$t"
done

echo "==> Generating Swift bindings..."
# Build for host first (uniffi-bindgen needs host dylib)
cargo build -p zdb-core --release
cargo run -p zdb-core --bin uniffi-bindgen -- generate \
    --library "$ROOT/target/release/libzdb_core.dylib" \
    --language swift \
    --out-dir "$OUT"

echo "==> Creating fat library for simulator (arm64 + x86_64)..."
mkdir -p "$OUT/sim-fat"
lipo -create \
    "$ROOT/target/aarch64-apple-ios-sim/release/$LIB_NAME" \
    "$ROOT/target/x86_64-apple-ios/release/$LIB_NAME" \
    -output "$OUT/sim-fat/$LIB_NAME"

echo "==> Creating XCFramework..."
rm -rf "$OUT/ZettelDB.xcframework"
xcodebuild -create-xcframework \
    -library "$ROOT/target/aarch64-apple-ios/release/$LIB_NAME" \
    -library "$OUT/sim-fat/$LIB_NAME" \
    -library "$ROOT/target/aarch64-apple-darwin/release/$LIB_NAME" \
    -output "$OUT/ZettelDB.xcframework"

rm -rf "$OUT/sim-fat"

echo "==> Done: $OUT/ZettelDB.xcframework"
echo "   Swift source: $OUT/zdb.swift"
